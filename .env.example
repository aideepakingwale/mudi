# MuDi — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values below
# 3. NEVER commit .env to git (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ── Core (REQUIRED) ──────────────────────────────────────────────────────────

# Full public URL of your app — no trailing slash
# Local dev:  http://localhost:8080
# Render:     https://mudi.onrender.com
BASE_URL=http://localhost:8080

# Session secret — must be a long random string, keep private
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING

# Set to "production" on any deployed server (enables secure cookies, HTTPS)
NODE_ENV=development

# ── Server (optional) ────────────────────────────────────────────────────────

# Port — Render sets this automatically, do not change for production
PORT=8080

# Path for SQLite database file
# Render production default: /app/data (created by Dockerfile)
# Local default:             ./data
# DATA_DIR=/app/data

# ── Cloudflare R2 (STRONGLY RECOMMENDED) ─────────────────────────────────────
# Used for TWO purposes:
#   1. Fast file transfer — host uploads to R2, listeners download from CDN
#   2. Database persistence — mudi.db backed up to R2 on every write
#      so user accounts, rooms, and scores survive Render redeploys
#
# Without R2: file transfers route through Render (slow), DB resets on redeploy
# With R2:    fast CDN transfers + persistent DB at zero cost
#
# Setup guide: README.md -> Section 6 (Configure Cloudflare R2)
# Dashboard:   https://dash.cloudflare.com -> R2 Object Storage
#
# After creating your bucket and API token, fill in all four values:
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mudi-transfers

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Enables "Sign in with Google" button on the login page
# Setup guide: README.md -> Section 7 (Configure Google Sign-In)
# Console:     https://console.cloud.google.com/apis/credentials
#
# Authorised redirect URI to register in Google Console:
#   https://mudi.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Facebook OAuth (optional) ─────────────────────────────────────────────────
# Enables "Continue with Facebook" button on the login page
# Setup guide: README.md -> Section 8 (Configure Facebook Login)
# Console:     https://developers.facebook.com/apps
#
# Valid OAuth Redirect URI to register in Meta Console:
#   https://mudi.onrender.com/auth/facebook/callback
#
# Also required in Meta app settings:
#   Privacy Policy URL: https://mudi.onrender.com/privacy
#   Terms of Service:   https://mudi.onrender.com/terms
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
