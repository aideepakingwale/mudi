# MuDi — Environment Variables
# ─────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values below
# 3. NEVER commit .env to git (it's already in .gitignore)
# ─────────────────────────────────────────────────────

# Server port (Render sets this automatically — don't change for production)
PORT=8080

# Full public URL of your app — no trailing slash
# Local dev:  http://localhost:8080
# Render:     https://mudi.onrender.com
# ngrok:      https://abc123.ngrok-free.app
BASE_URL=http://localhost:8080

# Session secret — REQUIRED. Must be a long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING

# Set to "production" on any deployed server
NODE_ENV=development

# ── Google OAuth (optional) ───────────────────────────────────────────────
# Setup guide: README.md → "Configure Google Sign-In"
# Console:     https://console.cloud.google.com/apis/credentials
# Callback URL you must register: ${BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Facebook OAuth (optional) ─────────────────────────────────────────────
# Setup guide: README.md → "Configure Facebook Login"
# Console:     https://developers.facebook.com/apps
# Callback URL you must register: ${BASE_URL}/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
